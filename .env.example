# ─── Whisper ──────────────────────────────────────────────────────────────────
# Modelo a ser usado. Opções: tiny, base, small, medium, large
# Modelos maiores são mais precisos mas mais lentos e pesados.
WHISPER_MODEL=base

# ─── Dados ────────────────────────────────────────────────────────────────────
# Diretório raiz para armazenar audio, video e transcrições.
# Em produção com Docker use /data (mapeado em volumes no docker-compose).
DATA_DIR=/data

# ─── Redis ────────────────────────────────────────────────────────────────────
# URL de conexão com o Redis (broker do Celery e armazenamento de jobs).
# Em Docker o hostname é o nome do serviço: redis
REDIS_URL=redis://redis:6379/0

# ─── Aplicação ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
