# ─── Whisper ──────────────────────────────────────────────────────────────────
# Modelo a ser usado com faster-whisper.
# Opções recomendadas (CPU): large-v3-turbo (melhor qualidade), small (mais leve)
# Opções disponíveis: tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
WHISPER_MODEL=large-v3-turbo

# ─── Dados ────────────────────────────────────────────────────────────────────
# Diretório raiz para armazenar audio, video e transcrições.
# Em produção com Docker use /data (mapeado em volumes no docker-compose).
DATA_DIR=/data

# ─── Redis ────────────────────────────────────────────────────────────────────
# URL de conexão com o Redis (broker do Celery e armazenamento de jobs).
# Em Docker o hostname é o nome do serviço: redis
REDIS_URL=redis://redis:6379/0

# ─── Aplicação ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
