server {
    listen 80;
    server_name {{ domain }};

    # Arquivos estáticos do frontend
    root {{ app_dir }}/frontend;
    index index.html;

    # Uploads grandes (vídeos)
    client_max_body_size 500M;

    # Frontend — serve arquivos estáticos diretamente
    location / {
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "public, max-age=3600";
    }

    # Cache de assets estáticos
    location ~* \.(css|js|ico|png|jpg|svg|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public, max-age=604800, immutable";
    }

    # API — proxy para o backend FastAPI
    # Nginx injeta a API key; o frontend nunca a vê
    location ~ ^/(transcriptions|health|ready) {
        proxy_pass         http://127.0.0.1:{{ app_port }};
        proxy_http_version 1.1;

        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-API-Key         "{{ api_key }}";

        # Necessário para uploads de arquivos grandes sem timeout
        proxy_request_buffering off;
        proxy_read_timeout      3600s;
        proxy_send_timeout      3600s;
        proxy_connect_timeout   60s;
    }
}
